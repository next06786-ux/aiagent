# LifeSwarm 环境配置示例
# 复制此文件为 .env 并修改配置

# ==================== 环境 ====================
LIFESWARM_ENV=development  # development, production, testing

# ==================== 数据库配置 ====================

# 知识图谱存储: 设置为 true 使用 Neo4j，false 使用内存
USE_NEO4J=false

# 信息中心知识图谱: 设置为 true 使用新架构（推荐），false 使用旧架构
USE_INFORMATION_KG=true

# 数据库类型: mysql, postgresql
DB_TYPE=mysql

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=lifeswarm
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=lifeswarm

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lifeswarm
POSTGRES_PASSWORD=your_password_here
POSTGRES_DATABASE=lifeswarm

# Neo4j 图数据库配置（知识图谱）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lifeswarm123
NEO4J_DATABASE=neo4j

# 连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== 缓存配置 ====================

# 缓存类型: memory, redis
CACHE_TYPE=memory

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=lifeswarm:

# 缓存设置
CACHE_TTL=3600  # 默认过期时间（秒）
CACHE_MAX_SIZE=1000  # 内存缓存最大条目数

# ==================== API 配置 ====================

# API 服务器
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS
CORS_ORIGINS=*

# ==================== 大模型配置 ====================

# 大模型提供商: openai, qwen, transformers
LLM_PROVIDER=qwen

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here

# 通义千问配置（阿里云百炼）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Transformers 本地推理（GPU 服务器）
# LLM_PROVIDER=transformers
# 使用 backend/llm/model_config.py 管理模型和量化配置

# Ollama 本地配置（免费，需要本地安装）
# LLM_PROVIDER=ollama
# 无需 API Key

# ==================== 其他配置 ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 文件上传
MAX_UPLOAD_SIZE=10485760  # 10MB
UPLOAD_DIR=uploads

# 自主运行
AUTONOMOUS_ENABLED=true
AUTONOMOUS_CHECK_INTERVAL=3600  # 1小时
