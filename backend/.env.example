# LifeSwarm 环境配置
# 复制此文件为 .env 并填写真实值

# ==================== 部署模式 ====================
LIFESWARM_ENV=production

# 是否启用本地 GPU 基座模型 + LoRA
# false = 轻量模式，推理走 Qwen API（适合 2核2GB 服务器）
# true  = 完整模式，加载本地 Qwen 基座 + LoRA 调度器（需要 GPU 服务器）
ENABLE_LOCAL_MODEL=false

# 决策推演链路
# api  = 当前主链，使用云端/API 推理
# lora = 保留兼容能力，切回本地个性模型推理时再启用
DECISION_INFERENCE_MODE=api

# LLM 提供商
# qwen = 使用 DashScope / OpenAI 兼容接口
LLM_PROVIDER=qwen

# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=lifeswarm
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=lifeswarm

# ==================== Neo4j 知识图谱 ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ==================== ChromaDB 向量数据库 ====================
# 嵌入式模式，数据存储在本地目录，无需单独启动服务
CHROMA_PATH=./data/chroma

# ==================== Qwen API ====================
# 用于：对话推理（qwen-plus）+ 向量 embedding（text-embedding-v3）
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key

# Embedding 维度（text-embedding-v3 = 1024）
EMBEDDING_DIM=1024

# ==================== API 服务 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

CORS_ORIGINS=*

# ==================== 缓存 ====================
# 轻量服务器用内存缓存，有 Redis 时可改为 redis
CACHE_TYPE=memory

# Redis 配置（CACHE_TYPE=redis 时填写）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==================== 连接池 ====================
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== 其他 ====================
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
AUTONOMOUS_ENABLED=true
AUTONOMOUS_CHECK_INTERVAL=3600
