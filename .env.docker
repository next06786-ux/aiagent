# Docker部署环境变量
# 复制此文件为 .env 并填写实际值

# ==================== LLM配置 ====================
# 通义千问API Key（必填）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==================== 数据库配置 ====================
# MySQL（由docker-compose自动配置）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=lifeswarm
MYSQL_PASSWORD=lifeswarm123
MYSQL_DATABASE=lifeswarm

# Neo4j（由docker-compose自动配置）
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lifeswarm123

# ==================== 应用配置 ====================
LIFESWARM_ENV=production
API_HOST=0.0.0.0
API_PORT=6006
