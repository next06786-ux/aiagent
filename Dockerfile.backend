# 后端 Dockerfile - 针对2核4G优化，利用Docker层缓存
FROM python:3.10-slim

# 设置工作目录
WORKDIR /app

# 配置Debian阿里云镜像源（加速apt安装）
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources

# 安装系统依赖（最小化）
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# 【关键优化】先复制requirements.txt，利用Docker层缓存
# 只有requirements.txt变化时才会重新安装依赖
COPY backend/requirements.txt .

# 安装Python依赖（使用腾讯云镜像，服务器在腾讯云最快+最全）
# 这一层会被缓存，除非requirements.txt变化
RUN pip install --no-cache-dir -r requirements.txt \
    -i https://mirrors.cloud.tencent.com/pypi/simple \
    --trusted-host mirrors.cloud.tencent.com \
    --timeout 100 \
    --retries 5

# 【最后复制代码】代码变化不会触发依赖重装
COPY backend/ ./backend/

# 创建必要的目录
RUN mkdir -p /app/faiss_indexes \
    /app/backend/data/persona_memories \
    /app/backend/data/decision_sessions \
    /app/backend/data/job_cache \
    /app/backend/data/education

# 暴露端口
EXPOSE 8000

# 设置环境变量
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# 启动命令 - 使用单worker避免进程间状态不一致
# 单worker + async可以处理大量并发连接，对于8GB内存的服务器更稳定
CMD ["python", "-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1", "--timeout-keep-alive", "120"]
