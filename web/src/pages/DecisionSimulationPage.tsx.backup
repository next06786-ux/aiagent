import { useEffect, useMemo, useRef, useState, useCallback } from 'react';
import { useLocation, useNavigate, useSearchParams } from 'react-router-dom';
import { DecisionGraphStage } from '../components/decision/DecisionGraphStage';
import { SimulationProgress } from '../components/decision/SimulationProgress';
import { ThinkingStream } from '../components/decision/ThinkingStream';
import { AgentThinkingPanel } from '../components/decision/AgentThinkingPanel';
import { StatusPill } from '../components/common/StatusPill';
import { useAuth } from '../hooks/useAuth';
import { getFutureOsSimulation } from '../services/futureOs';
import { openDecisionSimulationSocket } from '../services/decision';
import type {
  DecisionGraphNode,
  DecisionRecordPayload,
  DecisionSimulationRouteState,
  DecisionOption,
} from '../types/api';
import { ensureDecisionGraph, buildFallbackDecisionGraph } from '../utils/decisionGraph';

function buildLiveGraph(optionId: string, title: string, timeline: DecisionGraphNode[]) {
  return buildFallbackDecisionGraph(optionId, title, timeline);
}

function formatPercent(value?: number | null) {
  if (typeof value !== 'number' || Number.isNaN(value)) return '--';
  return `${Math.round(value * 100)}%`;
}

function getOptionLabel(optionId: string, fallbackTitle?: string): string {
  // 优先使用传入的完整标题
  if (fallbackTitle && fallbackTitle !== optionId && !fallbackTitle.startsWith('option_')) {
    return fallbackTitle;
  }
  
  // 如果没有有效的标题，尝试从 option_id 生成中文标签
  const match = optionId.match(/^option_(\d+)$/);
  if (match) {
    const num = parseInt(match[1]);
    const chineseNumbers = ['', '一', '二', '三', '四', '五', '六', '七', '八', '九', '十'];
    if (num > 0 && num <= 10) {
      return `选项${chineseNumbers[num]}`;
    }
    return `选项${num}`;
  }
  
  // 最后返回原始ID
  return optionId;
}

function parseRouteState(
  state: unknown,
  fallbackUserId: string,
  searchParams: URLSearchParams,
): DecisionSimulationRouteState {
  const routeState = (state || {}) as Partial<DecisionSimulationRouteState>;
  return {
    mode: routeState.mode || (searchParams.get('simulationId') ? 'history' : 'future'),
    sessionId: routeState.sessionId,
    simulationId: routeState.simulationId || searchParams.get('simulationId') || undefined,
    dungeonId: routeState.dungeonId,
    question: routeState.question || searchParams.get('question') || '决策分析工作台',
    userId: routeState.userId || fallbackUserId,
    options: routeState.options,
    collectedInfo: routeState.collectedInfo || null,
    record: routeState.record,
    scenario: routeState.scenario,
    decisionType: routeState.decisionType,
  };
}

function stateEntries(value?: Record<string, string | number | boolean | null>) {
  return Object.entries(value || {}).filter(([, item]) => item !== undefined && item !== '');
}

function impactEntries(value?: Record<string, number>) {
  return Object.entries(value || {}).sort((l, r) => Math.abs(r[1]) - Math.abs(l[1]));
}

function riskTone(level?: string) {
  if (level === 'high') return 'danger';
  if (level === 'medium') return 'warning';
  return 'success';
}

export function DecisionSimulationPage() {
  const navigate = useNavigate();
  const location = useLocation();
  const [searchParams] = useSearchParams();
  const { user } = useAuth();
  const config = useMemo(
    () => parseRouteState(location.state, user?.user_id || '', searchParams),
    [location.state, searchParams, user],
  );

  const [record, setRecord] = useState<DecisionRecordPayload | null>(config.record || null);
  const [selectedOptionIndex, setSelectedOptionIndex] = useState(0);
  const [selectedNodeId, setSelectedNodeId] = useState('');
  const [error, setError] = useState('');
  const [isLoading, setIsLoading] = useState(!config.record);
  const [showNodeDetail, setShowNodeDetail] = useState(false);
  const [showThinkingPanel, setShowThinkingPanel] = useState(true);
  const [expandedThinking, setExpandedThinking] = useState<Set<string>>(new Set());

  const [wsStatus, setWsStatus] = useState<string>('');
  const [wsStage, setWsStage] = useState<string>('idle');
  const [wsPhase, setWsPhase] = useState<'idle' | 'connecting' | 'running' | 'done'>('idle');
  const wsPhaseRef = useRef<'idle' | 'connecting' | 'running' | 'done'>('idle');
  
  // 监控 wsPhase 变化
  useEffect(() => {
    console.log('[决策分析] wsPhase 变化:', wsPhase);
  }, [wsPhase]);
  const [liveOptions, setLiveOptions] = useState<Map<string, DecisionOption>>(new Map());
  const [currentOptionIndex, setCurrentOptionIndex] = useState<number | undefined>(undefined);
  const [thinkingContent, setThinkingContent] = useState<Map<string, string>>(new Map());
  const [currentThinkingOption, setCurrentThinkingOption] = useState<string>('');
  const [agentProgress, setAgentProgress] = useState<Map<string, { latestNode: DecisionGraphNode; thinking: string }>>(new Map());
  
  // Agent可视化状态 - 改为按option_id分组
  const [agentsByOption, setAgentsByOption] = useState<Map<string, Array<{id: string; name: string; status: string; score?: number}>>>(new Map());
  const [currentMonthByOption, setCurrentMonthByOption] = useState<Map<string, number>>(new Map());
  const [isCommunicatingByOption, setIsCommunicatingByOption] = useState<Map<string, boolean>>(new Map());
  const [communicationMessageByOption, setCommunicationMessageByOption] = useState<Map<string, string>>(new Map());
  
  const wsCloseRef = useRef<(() => void) | null>(null);
  
  // 退出确认对话框状态
  const [showExitConfirm, setShowExitConfirm] = useState(false);
  const [pendingNavigation, setPendingNavigation] = useState<string | null>(null);

  // 监控Agent状态变化
  useEffect(() => {
    console.log('[Agent面板] 状态变化:', {
      wsPhase,
      agentsByOptionSize: agentsByOption.size,
      currentMonthByOptionSize: currentMonthByOption.size,
      agentsByOption: Array.from(agentsByOption.entries()).map(([optionId, agents]) => ({
        optionId,
        agentsCount: agents.length,
        agents: agents.map(a => ({ id: a.id, name: a.name, status: a.status }))
      }))
    });
  }, [agentsByOption, currentMonthByOption, wsPhase]);

  // 添加错误处理
  useEffect(() => {
    const handleError = (event: ErrorEvent) => {
      console.error('[全局错误]', event.error);
      setError(`页面错误: ${event.error?.message || '未知错误'}`);
    };
    
    const handleUnhandledRejection = (event: PromiseRejectionEvent) => {
      console.error('[未处理的Promise拒绝]', event.reason);
      setError(`异步错误: ${event.reason?.message || '未知错误'}`);
    };

    window.addEventListener('error', handleError);
    window.addEventListener('unhandledrejection', handleUnhandledRejection);

    return () => {
      window.removeEventListener('error', handleError);
      window.removeEventListener('unhandledrejection', handleUnhandledRejection);
    };
  }, []);

  useEffect(() => {
    if (config.mode !== 'future' || !config.sessionId || !config.options?.length) return;
    
    console.log('[推演页面] 建立 WebSocket 连接, sessionId:', config.sessionId);
    console.log('[推演页面] 选项数量:', config.options.length);
    
    // 清除localStorage中的旧标记
    localStorage.removeItem('lastSimulationCompleted');
    
    // 清除所有状态，确保是全新的推演
    setLiveOptions(new Map());
    setRecord(null);
    setAgentsByOption(new Map());
    setCurrentMonthByOption(new Map());
    setIsCommunicatingByOption(new Map());
    setCommunicationMessageByOption(new Map());
    setThinkingContent(new Map());
    setAgentProgress(new Map());
    setSelectedNodeId('');
    
    setWsPhase('connecting');
    setWsStatus('正在连接推演服务器...');
    setIsLoading(false);

    let isActive = true;
    const wsInstances: Array<() => void> = [];
    let completedCount = 0;
    
    const setupWebSocket = () => {
      if (!config.sessionId || !config.options || !config.userId) {
        console.error('[推演页面] sessionId、options 或 userId 为空');
        return;
      }
      
      console.log(`[推演页面] 准备为 ${config.options.length} 个选项建立并行WebSocket连接`);
      
      // 为每个选项建立独立的WebSocket连接 - 并行执行
      config.options.forEach((option, index) => {
        console.log(`[推演页面] 启动选项 ${index + 1}/${config.options?.length} 的WebSocket:`, option.title);
        
        const wsInstance = openDecisionSimulationSocket(
          {
            session_id: config.sessionId!,
            user_id: config.userId,
            question: config.question,
            option: {
              title: option.title,
              description: option.description || '',
            },
            option_index: index,
            collected_info: config.collectedInfo || undefined,
            decision_type: config.decisionType || 'general',
          },
          {
            onEvent(event) {
          if (!isActive) return;
          
          try {
            const type = String(event.type || '');
            
            // 特别关注Agent相关消息
            if (type.startsWith('agent')) {
              console.log('[推演页面] 🤖 Agent消息:', type, event);
            } else {
              console.log('[推演页面] 收到消息:', type, event);
            }

            // 连接成功，开始推演
            console.log('[推演页面] 检查wsPhase:', { current: wsPhaseRef.current, state: wsPhase });
            if (wsPhaseRef.current === 'connecting') {
              console.log('[推演页面] 设置wsPhase为running');
              setWsPhase('running');
              wsPhaseRef.current = 'running';
            } else {
              console.log('[推演页面] wsPhase已经是:', wsPhaseRef.current);
            }

            if (type === 'status') {
              setWsStatus(String(event.content || ''));
              setWsStage(String(event.stage || 'processing'));
            }

            if (type === 'heartbeat') {
              // 心跳消息，更新状态但不打印过多日志
              setWsStatus(String(event.content || '正在生成中...'));
            }

            if (type === 'thinking_chunk') {
              const chunk = String(event.content || '');
              const optionId = String(event.option_id || '');
              const optionTitle = String(event.option_title || '');

              // 追加到该选项的思考内容
              setThinkingContent(prev => {
                const next = new Map(prev);
                const current = next.get(optionId) || '';
                next.set(optionId, current + chunk);
                return next;
              });

              // 更新机器人进度
              const sentences = chunk.split(/[。！？.!?]/);
              const lastSentence = sentences[sentences.length - 2] || sentences[sentences.length - 1] || '';
              const shortThinking = lastSentence.trim().substring(0, 80);

              setAgentProgress(prevProgress => {
                const nextProgress = new Map(prevProgress);
                nextProgress.set(optionTitle, {
                  latestNode: null as any,
                  thinking: shortThinking || 'AI正在思考...',
                });
                return nextProgress;
              });

              setCurrentThinkingOption(optionTitle);
            }

            if (type === 'option_start') {
              const optId = String(event.option_id || '');
              const title = String(event.title || event.option_title || optId);
              console.log('[推演页面] ========== 开始新选项 ==========');
              console.log('[推演页面] option_id:', optId);
              console.log('[推演页面] title:', title);
              console.log('[推演页面] =====================================');
              
              const match = optId.match(/option_(\d+)/);
              if (match) {
                setCurrentOptionIndex(parseInt(match[1]) - 1);
              }
              // 初始化思考内容
              setThinkingContent(prev => {
                const next = new Map(prev);
                next.set(optId, '');
                return next;
              });
              setCurrentThinkingOption(title);
              setLiveOptions(prev => {
                const next = new Map(prev);
                if (!next.has(optId)) {
                  console.log('[推演页面] 创建新选项:', optId);
                  next.set(optId, {
                    option_id: optId, title, description: '',
                    timeline: [], decision_graph: null,
                    final_score: 0, risk_level: 0,
                    execution_confidence: 0, dropout_risk_month: null, personal_note: '',
                  });
                } else {
                  console.log('[推演页面] 选项已存在:', optId);
                }
                return next;
              });
              // 自动展开第一个选项
              setExpandedThinking(prev => {
                if (prev.size === 0) {
                  return new Set([optId]);
                }
                return prev;
              });
            }

            // Agent可视化消息处理 - 按option_id分组
            if (type === 'agents_start') {
              const agents = (event.agents as any[]) || [];
              const month = (event.month as number) || 0;
              const optionId = String(event.option_id || '');
              
              console.log('='.repeat(80));
              console.log('[Agent面板] ✅ 收到agents_start消息');
              console.log('[Agent面板] option_id:', optionId);
              console.log('[Agent面板] agents数量:', agents.length);
              console.log('[Agent面板] month:', month);
              console.log('='.repeat(80));
              
              if (optionId) {
                // 更新该选项的Agent状态
                setAgentsByOption(prev => {
                  const next = new Map(prev);
                  next.set(optionId, agents.map((a: any) => ({
                    id: String(a.id),
                    name: String(a.name),
                    status: (month === 0 ? 'waiting' : (a.status || 'waiting')) as 'waiting' | 'thinking' | 'complete' | 'error',
                    score: undefined
                  })));
                  return next;
                });
                
                setCurrentMonthByOption(prev => {
                  const next = new Map(prev);
                  next.set(optionId, month === 0 ? 1 : month);
                  return next;
                });
                
                setIsCommunicatingByOption(prev => {
                  const next = new Map(prev);
                  next.set(optionId, false);
                  return next;
                });
              }
              
              console.log('[Agent面板] 状态已更新');
            }

            if (type === 'agent_thinking') {
              const agentId = event.agent_id;
              const optionId = String(event.option_id || '');
              console.log('[Agent面板] Agent开始思考:', optionId, agentId);
              
              if (optionId) {
                setAgentsByOption(prev => {
                  const next = new Map(prev);
                  const agents = next.get(optionId) || [];
                  next.set(optionId, agents.map(a => 
                    a.id === agentId ? { ...a, status: 'thinking' as const } : a
                  ));
                  return next;
                });
              }
            }

            if (type === 'agent_complete') {
              const agentId = event.agent_id;
              const optionId = String(event.option_id || '');
              const score = typeof event.score === 'number' ? event.score : undefined;
              console.log('[Agent面板] Agent完成:', optionId, agentId, '得分:', score);
              
              if (optionId) {
                setAgentsByOption(prev => {
                  const next = new Map(prev);
                  const agents = next.get(optionId) || [];
                  next.set(optionId, agents.map(a => 
                    a.id === agentId ? { ...a, status: 'complete' as const, score } : a
                  ));
                  return next;
                });
              }
            }

            if (type === 'agent_error') {
              const agentId = event.agent_id;
              const optionId = String(event.option_id || '');
              
              if (optionId) {
                setAgentsByOption(prev => {
                  const next = new Map(prev);
                  const agents = next.get(optionId) || [];
                  next.set(optionId, agents.map(a => 
                    a.id === agentId ? { ...a, status: 'error' as const } : a
                  ));
                  return next;
                });
              }
            }

            if (type === 'agents_communicating') {
              const optionId = String(event.option_id || '');
              const message = String(event.message || 'Agent间正在交换信息...');
              
              if (optionId) {
                setIsCommunicatingByOption(prev => {
                  const next = new Map(prev);
                  next.set(optionId, true);
                  return next;
                });
                
                setCommunicationMessageByOption(prev => {
                  const next = new Map(prev);
                  next.set(optionId, message);
                  return next;
                });
              }
            }

            if (type === 'node') {
              const optId = String(event.option_id || '');
              const node = event.node as DecisionGraphNode;
              if (!node || !node.event_id) {
                console.warn('[推演页面] 收到无效节点:', event);
                return;
              }
              console.log(`[推演页面] ✓ 收到节点: ${optId} - M${node.month} - ${node.event.substring(0, 30)}...`);
              console.log(`[推演页面] 节点详情:`, {
                event_id: node.event_id,
                parent_event_id: node.parent_event_id,
                month: node.month,
                event: node.event,
                probability: node.probability,
                branch_strategy: node.branch_strategy,
                branch_group: node.branch_group,
              });
              console.log(`[推演页面] 原始WebSocket消息:`, JSON.stringify({
                type: event.type,
                option_id: event.option_id,
                node_event_id: node.event_id,
                node_parent_event_id: node.parent_event_id,
              }));
              
              // 使用单个状态更新，避免状态不同步
              setLiveOptions(prev => {
                const next = new Map(prev);
                const opt = next.get(optId);
                if (opt) {
                  const updated = { ...opt, timeline: [...opt.timeline, node as any] };
                  updated.decision_graph = buildLiveGraph(optId, opt.title, updated.timeline as any);
                  next.set(optId, updated);
                  console.log(`[推演页面] 更新选项 ${optId}，当前节点数: ${updated.timeline.length}`);
                  console.log(`[推演页面] 所有选项节点数:`, Array.from(next.entries()).map(([id, o]) => `${id}:${o.timeline.length}`).join(', '));
                  
                  // 更新机器人进度
                  setAgentProgress(prevProgress => {
                    const nextProgress = new Map(prevProgress);
                    nextProgress.set(opt.title, {
                      latestNode: node,
                      thinking: prevProgress.get(opt.title)?.thinking || '正在思考...',
                    });
                    return nextProgress;
                  });
                } else {
                  console.warn('[推演页面] 找不到选项:', optId);
                  console.warn('[推演页面] 当前所有选项:', Array.from(next.keys()));
                }
                return next;
              });
            }

            if (type === 'option_complete') {
              const optId = String(event.option_id || '');
              setLiveOptions(prev => {
                const next = new Map(prev);
                const opt = next.get(optId);
                if (opt) {
                  next.set(optId, {
                    ...opt,
                    final_score: Number(event.final_score) || opt.final_score,
                    risk_level: Number(event.risk_level) || opt.risk_level,
                    execution_confidence: Number(event.execution_confidence) || opt.execution_confidence,
                    dropout_risk_month: event.dropout_risk_month as number | null,
                    personal_note: String(event.personal_note || ''),
                    decision_graph: (event.decision_graph as DecisionOption['decision_graph']) || opt.decision_graph,
                  });
                }
                return next;
              });
            }

            if (type === 'done') {
              completedCount++;
              console.log(`[推演页面] 选项 ${index + 1} 推演完成 (${completedCount}/${config.options?.length || 0})`);
              
              // 所有选项都完成后，更新状态
              if (completedCount === (config.options?.length || 0)) {
                setWsPhase('done');
                setWsStatus('✓ 推演完成！所有分支已生成');
                localStorage.setItem('lastSimulationCompleted', 'true');
                console.log('[推演页面] 所有选项推演完成');
              }
            }

            if (type === 'recommendation') {
              const content = String(event.content || '');
              setRecord(prev => prev ? { ...prev, recommendation: content } : prev);
            }

            if (type === 'error') {
              const errorMsg = String(event.content || 'WebSocket 推演失败');
              console.error('[推演页面] 错误:', errorMsg);
              setError(errorMsg);
              setWsPhase('done');
            }
          } catch (err) {
            console.error('[推演页面] 消息处理错误:', err, event);
            setError(`消息处理错误: ${err instanceof Error ? err.message : '未知错误'}`);
          }
        },
        onError(msg) {
          if (!isActive) return;
          console.error(`[推演页面] 选项 ${index + 1} (${option.title}) WebSocket错误:`, msg);
          setError(`选项 ${index + 1} (${option.title}) 连接错误: ${msg}`);
        },
      },
    );
    
    wsInstances.push(wsInstance);
  });
  
  console.log(`[推演页面] ✅ 已启动 ${wsInstances.length} 个并行WebSocket连接`);
  
  // 连接成功后，设置为running状态
  setTimeout(() => {
    if (isActive && wsPhaseRef.current === 'connecting') {
      setWsPhase('running');
      wsPhaseRef.current = 'running';
      console.log('[推演页面] 所有WebSocket连接已建立，开始并行推演');
    }
  }, 1000);
    
    wsCloseRef.current = () => {
      console.log('[推演页面] 关闭所有WebSocket连接');
      wsInstances.forEach(close => close());
    };
    };
    
    setupWebSocket();
    
    return () => {
      console.log('[推演页面] useEffect cleanup');
      isActive = false;
      if (wsCloseRef.current) {
        console.log('[推演页面] 关闭所有 WebSocket');
        wsCloseRef.current();
      }
    };
  }, [config.sessionId, config.mode, config.userId, config.question, config.collectedInfo, config.decisionType]); // 添加所有必要的依赖

  // 移除这个 useEffect，因为我们在 node 消息处理中直接更新 record

  // 同步 liveOptions 到 record - 显示各个选项的独立视图
  useEffect(() => {
    // 推演模式：即使没有数据也要创建初始record
    if (config.mode === 'future' && config.options && wsPhase !== 'idle') {
      if (liveOptions.size > 0) {
        // 有实时数据时，更新record
        const opts = Array.from(liveOptions.values());
        
        console.log('[推演页面] ========== 更新选项数据 ==========');
        console.log('[推演页面] liveOptions 大小:', liveOptions.size);
        console.log('[推演页面] 各选项节点数:', opts.map(o => `${o.title}: ${o.timeline.length}`).join(', '));
        
        // 为每个选项构建独立的决策图谱
        const optionsWithGraphs = opts.map((opt, optIndex) => {
          console.log(`[推演页面] 处理选项 ${opt.option_id}:`, {
            title: opt.title,
            timelineLength: opt.timeline.length,
            firstNode: opt.timeline[0]?.event?.substring(0, 30),
            lastNode: opt.timeline[opt.timeline.length - 1]?.event?.substring(0, 30),
          });
          
          return {
            ...opt,
            decision_graph: opt.timeline.length > 0 
              ? buildFallbackDecisionGraph(opt.option_id, opt.title, opt.timeline as any)
              : null,
          };
        });
        
        console.log('[推演页面] 各选项图谱节点数:', optionsWithGraphs.map(o => `${o.title}: ${o.decision_graph?.nodes?.length || 0}`).join(', '));
        console.log('[推演页面] ========================================');
        
        setRecord(prevRecord => ({
          simulation_id: prevRecord?.simulation_id || `live_${Date.now()}`,
          user_id: config.userId,
          question: config.question,
          options_count: opts.length,
          recommendation: prevRecord?.recommendation || '',
          options: optionsWithGraphs,
          created_at: prevRecord?.created_at || new Date().toISOString(),
        }));
      } else if (!record) {
        // 推演刚开始，还没有数据，创建初始record
        console.log('[推演页面] 创建初始record，选项数:', config.options.length);
        const initialOptions = config.options.map((opt, idx) => ({
          option_id: `option_${idx + 1}`,
          title: opt.title,
          description: opt.description || '',
          timeline: [],
          decision_graph: null,
          final_score: 0,
          risk_level: 0,
          execution_confidence: 0,
          dropout_risk_month: null,
          personal_note: '',
        }));
        
        setRecord({
          simulation_id: `live_${Date.now()}`,
          user_id: config.userId,
          question: config.question,
          options_count: config.options.length,
          recommendation: '',
          options: initialOptions,
          created_at: new Date().toISOString(),
        });
      }
    }
  }, [liveOptions, config.userId, config.question, config.mode, config.options, wsPhase, record]);

  useEffect(() => {
    if (config.record || !config.simulationId) {
      setIsLoading(false);
      return;
    }

    let active = true;
    setIsLoading(true);
    setError('');

    getFutureOsSimulation(config.simulationId)
      .then((payload) => {
        if (active) setRecord(payload);
      })
      .catch((loadError) => {
        if (active) {
          setError(loadError instanceof Error ? loadError.message : '推演详情加载失败');
        }
      })
      .finally(() => {
        if (active) setIsLoading(false);
      });

    return () => {
      active = false;
    };
  }, [config.record, config.simulationId]);

  const activeOption: DecisionOption | null = record?.options[selectedOptionIndex] || null;
  const activeGraph = useMemo(() => {
    console.log('[activeGraph] 重新计算:', {
      mode: config.mode,
      wsPhase,
      selectedOptionIndex,
      liveOptionsSize: liveOptions.size,
      recordOptionsLength: record?.options.length,
      activeOptionId: activeOption?.option_id
    });
    
    // 历史记录模式
    if (activeOption && config.mode !== 'future') {
      console.log('[activeGraph] 使用历史记录模式');
      return ensureDecisionGraph(activeOption);
    }
    
    // Future模式 - 正在推演
    if (config.mode === 'future') {
      // 如果正在推演但还没有节点，返回空图谱（只显示Decision Core起点）
      if (wsPhase === 'running' && liveOptions.size === 0) {
        console.log('[activeGraph] 推演中但无数据，返回空图谱');
        return {
          graph_id: 'initial',
          schema_version: 1,
          graph_summary: {
            title: '决策推演',
            node_count: 0,
            edge_count: 0,
            high_risk_nodes: 0,
            dominant_axes: [],
            agent_stance_mix: {},
          },
          nodes: [],
          edges: [],
        };
      }
      
      // 有实时数据时，从record中获取当前选中的选项
      if (record && record.options[selectedOptionIndex]) {
        const currentOption = record.options[selectedOptionIndex];
        console.log('[activeGraph] 使用实时数据:', {
          optionId: currentOption.option_id,
          title: currentOption.title,
          nodesCount: currentOption.decision_graph?.nodes?.length || 0
        });
        return currentOption.decision_graph;
      }
    }
    
    console.log('[activeGraph] 无可用图谱');
    return null;
  }, [activeOption, config.mode, wsPhase, liveOptions.size, selectedOptionIndex, record]);

  useEffect(() => {
    if (!activeGraph?.nodes?.length) {
      setSelectedNodeId('');
      return;
    }

    const stillExists = activeGraph.nodes.some((node) => node.event_id === selectedNodeId);
    if (!stillExists) {
      setSelectedNodeId(activeGraph.nodes[0].event_id);
    }
  }, [activeGraph, selectedNodeId]);

  const selectedNode: DecisionGraphNode | null =
    activeGraph?.nodes.find((node) => node.event_id === selectedNodeId) || null;

  // 处理返回按钮点击
  const handleBackClick = useCallback((targetPath: string) => {
    console.log('[退出确认] 检查推演状态:', {
      wsPhase,
      liveOptionsSize: liveOptions.size,
      hasNodes: Array.from(liveOptions.values()).some(opt => opt.timeline.length > 0),
      isSimulationComplete: wsPhase === 'done',
    });
    
    // 如果推演正在进行中或有未保存的数据，显示确认对话框
    // 条件：(1) 正在推演 或 (2) 有节点数据但不是历史记录模式
    const hasLiveData = liveOptions.size > 0 && Array.from(liveOptions.values()).some(opt => opt.timeline.length > 0);
    const isInProgress = wsPhase === 'running' || wsPhase === 'connecting';
    const shouldConfirm = (isInProgress || hasLiveData) && config.mode === 'future';
    
    console.log('[退出确认] 判断结果:', { hasLiveData, isInProgress, shouldConfirm });
    
    if (shouldConfirm) {
      console.log('[退出确认] 显示确认对话框');
      setPendingNavigation(targetPath);
      setShowExitConfirm(true);
    } else {
      console.log('[退出确认] 直接跳转');
      // 推演已完成或未开始，直接跳转
      navigate(targetPath);
    }
  }, [wsPhase, liveOptions, config.mode, navigate]);

  // 确认保留内容并退出
  const handleKeepAndExit = useCallback(() => {
    console.log('[推演页面] 用户选择保留内容并退出，推演继续在后台运行');
    // 保留 localStorage 标记
    localStorage.setItem('lastSimulationCompleted', 'partial');
    // 不关闭 WebSocket，让推演继续在后台运行
    console.log('[推演页面] WebSocket保持连接，推演继续');
    setShowExitConfirm(false);
    if (pendingNavigation) {
      navigate(pendingNavigation);
    }
  }, [pendingNavigation, navigate]);

  // 确认清空内容并退出
  const handleClearAndExit = useCallback(() => {
    console.log('[推演页面] 用户选择清空内容并退出');
    // 关闭 WebSocket
    if (wsCloseRef.current) {
      console.log('[推演页面] 关闭WebSocket连接');
      wsCloseRef.current();
      wsCloseRef.current = null;
    }
    // 清空所有状态
    setLiveOptions(new Map());
    setRecord(null);
    setAgentsByOption(new Map());
    setCurrentMonthByOption(new Map());
    setIsCommunicatingByOption(new Map());
    setCommunicationMessageByOption(new Map());
    setThinkingContent(new Map());
    setAgentProgress(new Map());
    setWsPhase('idle');
    // 清除 localStorage
    localStorage.removeItem('lastSimulationCompleted');
    setShowExitConfirm(false);
    // 返回到主界面
    navigate('/');
  }, [navigate]);

  // 取消退出
  const handleCancelExit = useCallback(() => {
    setShowExitConfirm(false);
    setPendingNavigation(null);
  }, []);

  // 重新开始推演
  const handleRestartSimulation = useCallback(() => {
    console.log('[推演页面] 用户选择重新开始推演');
    
    // 显示确认对话框
    if (!window.confirm('确定要重新开始推演吗？\n\n当前的推演进度将被清空，系统将重新开始推演。')) {
      return;
    }
    
    // 1. 关闭当前 WebSocket
    if (wsCloseRef.current) {
      console.log('[推演页面] 关闭当前WebSocket连接');
      wsCloseRef.current();
      wsCloseRef.current = null;
    }
    
    // 2. 清空所有状态
    setLiveOptions(new Map());
    setAgentsByOption(new Map());
    setCurrentMonthByOption(new Map());
    setIsCommunicatingByOption(new Map());
    setCommunicationMessageByOption(new Map());
    setThinkingContent(new Map());
    setAgentProgress(new Map());
    setSelectedNodeId('');
    setError('');
    
    // 3. 重置推演阶段
    setWsPhase('connecting');
    
    // 4. 触发重新连接（通过修改一个依赖项来触发useEffect重新执行）
    // 使用一个时间戳来强制重新连接
    console.log('[推演页面] 准备重新建立WebSocket连接');
    
    // 延迟一下，确保旧连接完全关闭
    setTimeout(() => {
      // 通过修改config来触发useEffect重新执行
      // 这里我们可以添加一个时间戳参数
      window.location.reload(); // 简单方式：重新加载页面
    }, 100);
  }, []);

  // 添加浏览器返回/刷新拦截
  useEffect(() => {
    const handleBeforeUnload = (e: BeforeUnloadEvent) => {
      const hasLiveData = liveOptions.size > 0 && Array.from(liveOptions.values()).some(opt => opt.timeline.length > 0);
      const isInProgress = wsPhase === 'running' || wsPhase === 'connecting';
      
      if ((isInProgress || hasLiveData) && config.mode === 'future') {
        e.preventDefault();
        e.returnValue = '推演正在进行中，确定要离开吗？未保存的进度将会丢失。';
        return e.returnValue;
      }
    };

    window.addEventListener('beforeunload', handleBeforeUnload);
    return () => {
      window.removeEventListener('beforeunload', handleBeforeUnload);
    };
  }, [wsPhase, liveOptions, config.mode]);

  // 添加渲染保护 - 允许在推演开始时就显示Decision Core
  const canRenderGraph = useMemo(() => {
    // 历史记录模式：必须有完整数据
    if (record) {
      return activeGraph && activeGraph.nodes && activeGraph.nodes.length > 0;
    }
    
    // Future模式：推演开始就显示（即使没有节点，也显示Decision Core起点）
    if (config.mode === 'future' && wsPhase === 'running') {
      return true;
    }
    
    // 有实时数据时显示
    if (liveOptions.size > 0) {
      return true;
    }
    
    return false;
  }, [record, activeGraph, config.mode, wsPhase, liveOptions.size]);

  return (
    <div style={{ 
      position: 'fixed', top: 0, left: 0, right: 0, bottom: 0, 
      background: 'linear-gradient(135deg, rgba(10, 89, 247, 0.03) 0%, rgba(107, 72, 255, 0.02) 100%), #FFFFFF',
      overflow: 'hidden', display: 'flex', flexDirection: 'column' 
    }}>
      {/* 添加CSS动画 */}
      <style>{`
        @keyframes pulse {
          0%, 100% {
            opacity: 1;
            transform: scale(1);
          }
          50% {
            opacity: 0.5;
            transform: scale(1.2);
          }
        }
        @keyframes spin {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
        @keyframes harmonyFadeIn {
          from { opacity: 0; }
          to { opacity: 1; }
        }
        @keyframes harmonyFadeInUp {
          from { opacity: 0; transform: translateY(20px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes harmonyFadeInDown {
          from { opacity: 0; transform: translateY(-20px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes blink {
          0%, 100% { opacity: 1; }
          50% { opacity: 0; }
        }
      `}</style>
      
      {/* 移除重复的BackButton，使用导航栏中的返回按钮 */}
      {/* HarmonyOS 6 - 纯净顶部导航栏 */}
      <div style={{ 
        position: 'relative', zIndex: 100, display: 'flex', justifyContent: 'space-between', alignItems: 'center', 
        gap: 20, padding: '14px 24px',
        background: 'rgba(255, 255, 255, 0.95)', backdropFilter: 'blur(20px)', 
        borderBottom: '1px solid rgba(0, 0, 0, 0.06)', 
        boxShadow: '0 4px 24px rgba(0, 0, 0, 0.04)' 
      }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>
          {/* 返回按钮 - 纯净风格 */}
          <button onClick={() => handleBackClick('/emergence-dashboard')} style={{ 
            background: 'rgba(10, 89, 247, 0.06)', border: 'none', borderRadius: 12, 
            padding: '10px 16px', color: '#0A59F7', cursor: 'pointer', fontSize: 14, fontWeight: 600,
            display: 'flex', alignItems: 'center', gap: 6,
            transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
          }} 
          onMouseEnter={e => { e.currentTarget.style.background = 'rgba(10, 89, 247, 0.1)'; e.currentTarget.style.transform = 'translateX(-2px)'; }}
          onMouseLeave={e => { e.currentTarget.style.background = 'rgba(10, 89, 247, 0.06)'; e.currentTarget.style.transform = 'translateX(0)'; }}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            返回
          </button>
          
          {/* 标题区域 */}
          <div style={{ borderLeft: '1px solid rgba(0, 0, 0, 0.08)', paddingLeft: 16 }}>
            <div style={{ fontSize: 11, color: '#999', marginBottom: 4, letterSpacing: '0.1em', textTransform: 'uppercase' }}>决策图谱舞台</div>
            <div style={{ fontSize: 18, fontWeight: 700, color: '#1A1A1A', letterSpacing: '-0.01em' }}>{config.question}</div>
          </div>
          
          {/* 选项切换器 - 推演开始时就显示 */}
          {config.mode === 'future' && config.options && config.options.length > 1 && (
            <div style={{ 
              display: 'flex', 
              gap: 8, 
              alignItems: 'center',
              borderLeft: '1px solid rgba(0, 0, 0, 0.08)', 
              paddingLeft: 16 
            }}>
              <div style={{ 
                fontSize: 11, 
                color: '#999', 
                marginRight: 4,
                display: 'flex',
                alignItems: 'center',
                gap: 6
              }}>
                {wsPhase === 'running' && (
                  <div style={{
                    width: 8,
                    height: 8,
                    borderRadius: '50%',
                    background: '#34C759',
                    animation: 'pulse 2s infinite',
                  }} />
                )}
                {wsPhase === 'running' ? '并行推演中' : wsPhase === 'connecting' ? '准备推演' : '查看选项'}:
              </div>
              {config.options.map((option, idx) => {
                const isActive = idx === selectedOptionIndex;
                const branchColors = ['#0A59F7', '#6B48FF', '#FF9500'];
                const color = branchColors[idx % branchColors.length];
                
                // 从liveOptions获取实时节点数
                const liveOption = Array.from(liveOptions.values())[idx];
                const nodeCount = liveOption?.timeline?.length || 0;
                const isRunning = wsPhase === 'running' && nodeCount > 0;
                
                return (
                  <button
                    key={`option-${idx}`}
                    onClick={() => {
                      console.log(`[推演页面] 切换到选项 ${idx + 1}: ${option.title}`);
                      setSelectedOptionIndex(idx);
                    }}
                    style={{
                      background: isActive ? color : 'rgba(0, 0, 0, 0.04)',
                      border: isActive ? 'none' : `1px solid ${color}33`,
                      borderRadius: 10,
                      padding: '8px 16px',
                      color: isActive ? '#fff' : color,
                      cursor: 'pointer',
                      fontSize: 13,
                      fontWeight: 600,
                      transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
                      display: 'flex',
                      alignItems: 'center',
                      gap: 6,
                      position: 'relative',
                      boxShadow: isActive ? `0 4px 12px ${color}33` : 'none',
                    }}
                    onMouseEnter={e => {
                      if (!isActive) {
                        e.currentTarget.style.background = `${color}11`;
                        e.currentTarget.style.transform = 'translateY(-2px)';
                        e.currentTarget.style.boxShadow = `0 4px 12px ${color}22`;
                      }
                    }}
                    onMouseLeave={e => {
                      if (!isActive) {
                        e.currentTarget.style.background = 'rgba(0, 0, 0, 0.04)';
                        e.currentTarget.style.transform = 'translateY(0)';
                        e.currentTarget.style.boxShadow = 'none';
                      }
                    }}
                  >
                    {/* 推演进度指示器 */}
                    {isRunning && (
                      <div style={{
                        position: 'absolute',
                        top: -4,
                        right: -4,
                        width: 12,
                        height: 12,
                        borderRadius: '50%',
                        background: '#34C759',
                        border: '2px solid #fff',
                        boxShadow: '0 0 8px rgba(52, 199, 89, 0.6)',
                        animation: 'pulse 2s infinite',
                      }} />
                    )}
                    
                    <div style={{ 
                      width: 8, 
                      height: 8, 
                      borderRadius: '50%', 
                      background: isActive ? '#fff' : color,
                      boxShadow: isActive ? `0 0 8px ${color}66` : 'none'
                    }} />
                    
                    <span>{option.title}</span>
                    
                    {nodeCount > 0 && (
                      <span style={{ 
                        fontSize: 11, 
                        opacity: isActive ? 0.9 : 0.7,
                        marginLeft: 2,
                        fontWeight: 700
                      }}>
                        {nodeCount}节点
                      </span>
                    )}
                  </button>
                );
              })}
            </div>
          )}
          
          {/* 历史记录模式的选项切换器 */}
          {config.mode !== 'future' && record && record.options.length > 1 && (
            <div style={{ 
              display: 'flex', 
              gap: 8, 
              alignItems: 'center',
              borderLeft: '1px solid rgba(0, 0, 0, 0.08)', 
              paddingLeft: 16 
            }}>
              <div style={{ fontSize: 11, color: '#999', marginRight: 4 }}>查看选项:</div>
              {record.options.map((opt, idx) => {
                const isActive = idx === selectedOptionIndex;
                const branchColors = ['#0A59F7', '#6B48FF', '#FF9500'];
                const color = branchColors[idx % branchColors.length];
                const nodeCount = opt.timeline?.length || 0;
                
                return (
                  <button
                    key={opt.option_id}
                    onClick={() => setSelectedOptionIndex(idx)}
                    style={{
                      background: isActive ? color : 'rgba(0, 0, 0, 0.04)',
                      border: isActive ? 'none' : `1px solid ${color}33`,
                      borderRadius: 10,
                      padding: '8px 16px',
                      color: isActive ? '#fff' : color,
                      cursor: 'pointer',
                      fontSize: 13,
                      fontWeight: 600,
                      transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
                      display: 'flex',
                      alignItems: 'center',
                      gap: 6,
                      boxShadow: isActive ? `0 4px 12px ${color}33` : 'none',
                    }}
                    onMouseEnter={e => {
                      if (!isActive) {
                        e.currentTarget.style.background = `${color}11`;
                        e.currentTarget.style.transform = 'translateY(-2px)';
                      }
                    }}
                    onMouseLeave={e => {
                      if (!isActive) {
                        e.currentTarget.style.background = 'rgba(0, 0, 0, 0.04)';
                        e.currentTarget.style.transform = 'translateY(0)';
                      }
                    }}
                  >
                    <div style={{ 
                      width: 8, 
                      height: 8, 
                      borderRadius: '50%', 
                      background: isActive ? '#fff' : color,
                    }} />
                    <span>{getOptionLabel(opt.option_id, opt.title)}</span>
                    {nodeCount > 0 && (
                      <span style={{ 
                        fontSize: 11, 
                        opacity: isActive ? 0.9 : 0.7,
                        marginLeft: 2
                      }}>
                        {nodeCount}节点
                      </span>
                    )}
                  </button>
                );
              })}
            </div>
          )}
        </div>
        
        {/* 实时统计 - HarmonyOS 6 风格 */}
        {wsPhase === 'running' && liveOptions.size > 0 && (
          <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
            {Array.from(liveOptions.entries()).map(([optionId, opt]) => {
              const branchColors = ['#0A59F7', '#6B48FF', '#FF9500'];
              const index = Array.from(liveOptions.keys()).indexOf(optionId);
              const color = branchColors[index % branchColors.length];
              
              return (
                <div key={optionId} style={{ 
                  display: 'flex', alignItems: 'center', gap: 10, padding: '10px 16px', 
                  background: 'rgba(255, 255, 255, 0.9)', border: `1px solid ${color}22`, 
                  borderRadius: 14, backdropFilter: 'blur(12px)',
                  transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
                }}>
                  <div style={{ width: 10, height: 10, borderRadius: '50%', background: color, boxShadow: `0 0 12px ${color}66` }} />
                  <div>
                    <div style={{ fontSize: 11, color: '#999', letterSpacing: '0.05em' }}>{getOptionLabel(optionId, opt.title)}</div>
                    <div style={{ fontSize: 15, fontWeight: 700, color: color }}>{opt.timeline.length} 节点</div>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>

      {/* 推演进度 - HarmonyOS 6 风格 */}
      {wsPhase === 'running' && (
        <div style={{ 
          position: 'relative', zIndex: 90, padding: '12px 24px', 
          background: 'rgba(255, 255, 255, 0.95)', backdropFilter: 'blur(20px)', 
          borderBottom: '1px solid rgba(10, 89, 247, 0.1)',
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center'
        }}>
          <SimulationProgress stage={wsStage} content={wsStatus} optionsCount={config.options?.length || 0} currentOption={currentOptionIndex} />
          
          {/* 操作按钮组 */}
          <div style={{ display: 'flex', gap: 12, alignItems: 'center' }}>
            {/* 重新开始推演按钮 */}
            <button
              onClick={handleRestartSimulation}
              style={{
                background: 'rgba(255, 149, 0, 0.08)',
                border: '1px solid rgba(255, 149, 0, 0.2)',
                borderRadius: 12,
                padding: '10px 18px',
                color: '#FF9500',
                cursor: 'pointer',
                fontSize: 14,
                fontWeight: 600,
                display: 'flex',
                alignItems: 'center',
                gap: 8,
                transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
              }}
              onMouseEnter={e => {
                e.currentTarget.style.background = 'rgba(255, 149, 0, 0.15)';
                e.currentTarget.style.transform = 'translateY(-2px)';
                e.currentTarget.style.boxShadow = '0 4px 12px rgba(255, 149, 0, 0.2)';
              }}
              onMouseLeave={e => {
                e.currentTarget.style.background = 'rgba(255, 149, 0, 0.08)';
                e.currentTarget.style.transform = 'translateY(0)';
                e.currentTarget.style.boxShadow = 'none';
              }}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
                <polyline points="23 4 23 10 17 10"/>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
              </svg>
              重新开始
            </button>
            
            {/* 结束推演按钮 */}
            <button
              onClick={() => {
                if (window.confirm('确定要结束推演吗？\n\n当前已生成的节点将被保存，您可以查看已完成的部分。')) {
                  console.log('[推演页面] 用户手动结束推演');
                  // 关闭WebSocket
                  if (wsCloseRef.current) {
                    wsCloseRef.current();
                    wsCloseRef.current = null;
                  }
                  // 设置为完成状态
                  setWsPhase('done');
                  setWsStatus('✓ 推演已手动结束，已保存当前进度');
                // 设置完成标记
                localStorage.setItem('lastSimulationCompleted', 'true');
                // 清空Agent状态
                setAgentsByOption(new Map());
                setCurrentMonthByOption(new Map());
                setIsCommunicatingByOption(new Map());
                setCommunicationMessageByOption(new Map());
              }
            }}
            style={{
              background: 'linear-gradient(135deg, #FF3B30, #FF6259)',
              border: 'none',
              borderRadius: 12,
              padding: '10px 24px',
              color: '#fff',
              fontSize: 14,
              fontWeight: 600,
              cursor: 'pointer',
              display: 'flex',
              alignItems: 'center',
              gap: 8,
              boxShadow: '0 4px 16px rgba(255, 59, 48, 0.3)',
              transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
            }}
            onMouseEnter={e => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 6px 24px rgba(255, 59, 48, 0.4)';
            }}
            onMouseLeave={e => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = '0 4px 16px rgba(255, 59, 48, 0.3)';
            }}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <rect x="9" y="9" width="6" height="6"/>
            </svg>
            结束推演
          </button>
          </div>
        </div>
      )}
      
      {/* 主内容区域 - 图表 */}
      <div style={{ flex: 1, position: 'relative', overflow: 'hidden' }}>
        {/* 推演完成提示 */}
        {wsPhase === 'done' && canRenderGraph && (
          <div style={{
            position: 'absolute',
            top: 20,
            left: '50%',
            transform: 'translateX(-50%)',
            zIndex: 200,
            background: 'linear-gradient(135deg, #34C759 0%, #30D158 100%)',
            color: '#ffffff',
            padding: '16px 32px',
            borderRadius: 16,
            boxShadow: '0 8px 32px rgba(52, 199, 89, 0.3)',
            display: 'flex',
            alignItems: 'center',
            gap: 12,
            fontSize: 15,
            fontWeight: 600,
            animation: 'harmonyFadeInDown 0.5s cubic-bezier(0.4, 0, 0.2, 1)',
          }}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>推演完成！查看所有分支的决策图谱</span>
          </div>
        )}
        
        {canRenderGraph ? (
          <DecisionGraphStage 
            graph={activeGraph!} 
            accent="#5aa9ff" 
            selectedNodeId={selectedNodeId} 
            onSelect={(node) => { setSelectedNodeId(node.event_id); setShowNodeDetail(true); }} 
            fullscreen={false} 
            height={window.innerHeight - 80}
            agentProgress={wsPhase === 'running' ? agentProgress : undefined}
            agentsByOption={(() => {
              // 只传递当前选中选项的Agent状态
              if (wsPhase === 'running' && activeOption) {
                const currentOptionId = activeOption.option_id;
                const currentAgents = agentsByOption.get(currentOptionId);
                if (currentAgents) {
                  const map = new Map();
                  map.set(currentOptionId, currentAgents);
                  return map;
                }
              }
              return new Map();
            })()}
            isCommunicatingByOption={(() => {
              // 只传递当前选中选项的通信状态
              if (wsPhase === 'running' && activeOption) {
                const currentOptionId = activeOption.option_id;
                const isCommunicating = isCommunicatingByOption.get(currentOptionId);
                if (isCommunicating !== undefined) {
                  const map = new Map();
                  map.set(currentOptionId, isCommunicating);
                  return map;
                }
              }
              return new Map();
            })()}
            currentMonthByOption={(() => {
              // 只传递当前选中选项的月份
              if (wsPhase === 'running' && activeOption) {
                const currentOptionId = activeOption.option_id;
                const currentMonth = currentMonthByOption.get(currentOptionId);
                if (currentMonth !== undefined) {
                  const map = new Map();
                  map.set(currentOptionId, currentMonth);
                  return map;
                }
              }
              return new Map();
            })()}
          />
        ) : isLoading ? (
          // 加载历史记录状态
          <div style={{ 
            display: 'flex', alignItems: 'center', justifyContent: 'center', height: '100%',
          }}>
            <div style={{ textAlign: 'center' }}>
              <div style={{ 
                width: 48, height: 48, border: '3px solid #e2e8f0', borderTopColor: '#3b82f6',
                borderRadius: '50%', margin: '0 auto 16px',
                animation: 'spin 1s linear infinite',
              }} />
              <div style={{ fontSize: 16, fontWeight: 600, color: '#1e293b', marginBottom: 8 }}>正在加载推演图谱</div>
              <div style={{ fontSize: 14, color: '#64748b' }}>稍等一下...</div>
            </div>
          </div>
        ) : wsPhase === 'connecting' ? (
          // 连接中状态
          <div style={{ 
            display: 'flex', alignItems: 'center', justifyContent: 'center', height: '100%',
          }}>
            <div style={{ textAlign: 'center' }}>
              <div style={{ 
                width: 48, height: 48, border: '3px solid #e2e8f0', borderTopColor: '#3b82f6',
                borderRadius: '50%', margin: '0 auto 16px',
                animation: 'spin 1s linear infinite',
              }} />
              <div style={{ fontSize: 16, fontWeight: 600, color: '#1e293b', marginBottom: 8 }}>{wsStatus || '正在连接服务器'}</div>
              <div style={{ fontSize: 14, color: '#64748b' }}>等待推演引擎启动...</div>
            </div>
          </div>
        ) : wsPhase === 'running' ? (
          // 推演中状态 - 显示真实状态
          <div style={{
            display: 'flex',
            flexDirection: 'column',
            alignItems: 'center',
            justifyContent: 'center',
            height: '100%',
            padding: 32,
          }}>
            {/* 简单旋转加载动画 */}
            <div style={{
              width: 48,
              height: 48,
              border: '3px solid #e2e8f0',
              borderTopColor: '#3b82f6',
              borderRadius: '50%',
              marginBottom: 24,
              animation: 'spin 1s linear infinite',
            }} />

            <div style={{
              fontSize: 18,
              fontWeight: 600,
              color: '#1e293b',
              marginBottom: 12,
              textAlign: 'center',
            }}>
              AI 正在推演中
            </div>

            {/* 真实状态信息 */}
            <div style={{
              fontSize: 14,
              color: '#3b82f6',
              textAlign: 'center',
              maxWidth: 400,
              lineHeight: 1.6,
              padding: '16px 24px',
              background: '#f8fafc',
              borderRadius: 12,
              border: '1px solid #e2e8f0',
            }}>
              {wsStatus || '等待服务器响应...'}
            </div>

            {/* 当前选项进度 */}
            {currentOptionIndex !== undefined && config.options && (
              <div style={{
                marginTop: 20,
                fontSize: 13,
                color: '#64748b',
              }}>
                正在处理选项 {currentOptionIndex + 1} / {config.options.length}
              </div>
            )}

            {/* 已生成的节点统计 */}
            {liveOptions.size > 0 && (
              <div style={{
                marginTop: 16,
                fontSize: 13,
                color: '#64748b',
              }}>
                已生成 {Array.from(liveOptions.values()).reduce((sum, opt) => sum + (opt.timeline?.length || 0), 0)} 个节点
              </div>
            )}
          </div>
        ) : (
          // HarmonyOS 6 - 空状态
          <div style={{ 
            display: 'flex', alignItems: 'center', justifyContent: 'center', height: '100%',
            animation: 'harmonyFadeIn 0.5s ease-out'
          }}>
            <div style={{ textAlign: 'center', animation: 'harmonyFadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1)' }}>
              <div style={{ 
                width: 100, height: 100, borderRadius: '50%', margin: '0 auto 24px',
                background: 'linear-gradient(135deg, rgba(10, 89, 247, 0.06), rgba(107, 72, 255, 0.04))',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
              }}>
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#999" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
                  <circle cx="11" cy="11" r="8"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </div>
              <div style={{ fontSize: 20, fontWeight: 700, marginBottom: 8, color: '#1A1A1A' }}>未找到推演</div>
              <div style={{ fontSize: 14, color: '#666', marginBottom: 24, letterSpacing: '0.02em' }}>这条记录可能已经丢失或尚未生成</div>
              <button onClick={() => navigate('/decision')} style={{ 
                background: 'linear-gradient(135deg, #0A59F7, #6B48FF)', border: 'none', borderRadius: 14, 
                padding: '14px 28px', color: '#fff', fontSize: 14, fontWeight: 600, cursor: 'pointer',
                boxShadow: '0 8px 24px rgba(10, 89, 247, 0.25)',
                transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
              }}
              onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-2px)'; e.currentTarget.style.boxShadow = '0 12px 32px rgba(10, 89, 247, 0.35)'; }}
              onMouseLeave={e => { e.currentTarget.style.transform = 'translateY(0)'; e.currentTarget.style.boxShadow = '0 8px 24px rgba(10, 89, 247, 0.25)'; }}>
                返回决策副本
              </button>
            </div>
          </div>
        )}
      </div>
      
      {/* Agent可视化面板 - 显示所有路径的Agent（可选，如果需要独立面板） */}
      {agentsByOption.size > 0 && false && ( // 暂时隐藏，因为已经在图谱中显示
        <div style={{
          position: 'absolute', top: 80, left: 20, width: 500, zIndex: 100,
          pointerEvents: 'auto'
        }}>
          {Array.from(agentsByOption.entries()).map(([optionId, agents]) => (
            <div key={optionId} style={{ marginBottom: 16 }}>
              <div style={{ fontSize: 12, fontWeight: 600, marginBottom: 8 }}>
                {optionId}
              </div>
              <AgentThinkingPanel
                agents={agents as Array<{id: string; name: string; status: 'waiting' | 'thinking' | 'complete' | 'error'; score?: number}>}
                month={currentMonthByOption.get(optionId) || 0}
                isCommunicating={isCommunicatingByOption.get(optionId) || false}
                communicationMessage={communicationMessageByOption.get(optionId) || ''}
              />
            </div>
          ))}
        </div>
      )}
      
      {/* 调试面板 - 显示Agent状态 */}
      {agentsByOption.size > 0 && (
        <div style={{
          position: 'absolute', top: 80, right: 20, width: 300, zIndex: 100,
          background: 'rgba(0, 0, 0, 0.8)', color: '#fff', padding: 16,
          borderRadius: 8, fontSize: 12, fontFamily: 'monospace'
        }}>
          <div>调试信息</div>
          <div>wsPhase: {wsPhase}</div>
          <div>路径数量: {agentsByOption.size}</div>
          {Array.from(agentsByOption.entries()).map(([optionId, agents]) => (
            <div key={optionId} style={{ marginTop: 8, borderTop: '1px solid #444', paddingTop: 8 }}>
              <div>{optionId}:</div>
              {agents.map(a => (
                <div key={a.id} style={{ marginLeft: 8 }}>
                  {a.name}: {a.status} {a.score !== undefined ? `(${a.score})` : ''}
                </div>
              ))}
            </div>
          ))}
        </div>
      )}
      
      {/* 思考面板 - 3个路径分别显示 */}
      {wsPhase === 'running' && showThinkingPanel && thinkingContent.size > 0 && (
        <div style={{
          position: 'absolute', top: 80, right: 20, width: 420, maxHeight: 'calc(100vh - 120px)',
          overflowY: 'auto', zIndex: 100,
          background: 'rgba(255, 255, 255, 0.98)', backdropFilter: 'blur(24px)',
          border: '1px solid rgba(10, 89, 247, 0.1)', borderRadius: 24,
          padding: 20, boxShadow: '0 20px 60px rgba(0, 0, 0, 0.08)',
          pointerEvents: 'auto', animation: 'harmonyFadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1)'
        }}>
          <div style={{
            display: 'flex', justifyContent: 'space-between', alignItems: 'center',
            marginBottom: 16, paddingBottom: 16, borderBottom: '1px solid rgba(0, 0, 0, 0.06)'
          }}>
            <div style={{
              fontSize: 15, fontWeight: 700, color: '#1A1A1A',
              display: 'flex', alignItems: 'center', gap: 8,
              letterSpacing: '0.02em'
            }}>
              <div style={{
                width: 28, height: 28, borderRadius: 10,
                background: 'linear-gradient(135deg, #0A59F7, #6B48FF)',
                display: 'flex', alignItems: 'center', justifyContent: 'center',
              }}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
              </div>
              AI 思考过程
            </div>
            <button onClick={() => setShowThinkingPanel(false)} style={{
              background: 'rgba(0, 0, 0, 0.04)', border: 'none', borderRadius: 10,
              width: 36, height: 36, color: '#666', cursor: 'pointer', fontSize: 18,
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              transition: 'all 0.2s ease'
            }}
            onMouseEnter={e => { e.currentTarget.style.background = 'rgba(0, 0, 0, 0.08)'; e.currentTarget.style.color = '#1A1A1A'; }}
            onMouseLeave={e => { e.currentTarget.style.background = 'rgba(0, 0, 0, 0.04)'; e.currentTarget.style.color = '#666'; }}>×</button>
          </div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
            {Array.from(thinkingContent.entries()).map(([optionId, content]) => {
              const option = liveOptions.get(optionId);
              const isExpanded = expandedThinking.has(optionId);
              const title = option?.title || optionId;

              return (
                <div key={optionId} style={{
                  background: 'rgba(10, 89, 247, 0.04)',
                  border: '1px solid rgba(10, 89, 247, 0.08)',
                  borderRadius: 16, overflow: 'hidden',
                  transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)'
                }}>
                  <button
                    onClick={() => {
                      const next = new Set(expandedThinking);
                      if (isExpanded) {
                        next.delete(optionId);
                      } else {
                        next.add(optionId);
                      }
                      setExpandedThinking(next);
                    }}
                    style={{
                      width: '100%', background: 'none', border: 'none',
                      padding: '14px 18px', color: '#1A1A1A', cursor: 'pointer',
                      display: 'flex', justifyContent: 'space-between', alignItems: 'center',
                      fontSize: 14, fontWeight: 600,
                      transition: 'background 0.2s ease'
                    }}
                    onMouseEnter={e => e.currentTarget.style.background = 'rgba(10, 89, 247, 0.06)'}
                    onMouseLeave={e => e.currentTarget.style.background = 'none'}
                  >
                    <span style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                      <div style={{ width: 8, height: 8, borderRadius: '50%', background: '#0A59F7' }}/>
                      {title}
                    </span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"
                      style={{ transform: isExpanded ? 'rotate(180deg)' : 'rotate(0)', transition: 'transform 0.3s ease' }}>
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </button>
                  {isExpanded && (
                    <div style={{
                      padding: '0 18px 18px 18px', maxHeight: 300, overflowY: 'auto',
                      fontSize: 13, lineHeight: 1.7, color: '#666',
                      fontFamily: 'inherit', whiteSpace: 'pre-wrap', wordBreak: 'break-word',
                      animation: 'harmonyFadeIn 0.3s ease-out'
                    }}>
                      {content || '等待AI响应...'}
                      {content && (
                        <span style={{ display: 'inline-block', width: 6, height: 14, background: '#0A59F7', marginLeft: 4, borderRadius: 2, animation: 'blink 1s infinite' }} />
                      )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      )}
      
      {wsPhase === 'running' && !showThinkingPanel && thinkingContent.size > 0 && (
        <button
          onClick={() => setShowThinkingPanel(true)}
          style={{
            position: 'absolute', top: 80, right: 20, zIndex: 100,
            background: 'linear-gradient(135deg, #0A59F7, #6B48FF)', backdropFilter: 'blur(12px)',
            border: 'none', borderRadius: 16, padding: '14px 20px', color: '#fff', cursor: 'pointer',
            fontSize: 14, fontWeight: 600,
            boxShadow: '0 8px 32px rgba(10, 89, 247, 0.3)',
            pointerEvents: 'auto', transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
            animation: 'harmonyFadeIn 0.3s ease-out',
            display: 'flex', alignItems: 'center', gap: 8
          }}
          onMouseEnter={e => {
            e.currentTarget.style.transform = 'translateY(-2px)';
            e.currentTarget.style.boxShadow = '0 12px 40px rgba(10, 89, 247, 0.4)';
          }}
          onMouseLeave={e => {
            e.currentTarget.style.transform = 'translateY(0)';
            e.currentTarget.style.boxShadow = '0 8px 32px rgba(10, 89, 247, 0.3)';
          }}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          显示思考过程 ({thinkingContent.size})
        </button>
      )}

      {/* 节点详情面板 - HarmonyOS 6 纯净风格 */}
      {selectedNode && showNodeDetail && (
        <div style={{ 
          position: 'absolute', top: 80, right: 20, width: 420, maxHeight: 'calc(100vh - 120px)', 
          overflowY: 'auto', zIndex: 100, 
          background: 'rgba(255, 255, 255, 0.98)', backdropFilter: 'blur(24px)', 
          border: '1px solid rgba(10, 89, 247, 0.1)', borderRadius: 24, 
          padding: 24, boxShadow: '0 20px 60px rgba(0, 0, 0, 0.08)', 
          pointerEvents: 'auto', animation: 'harmonyFadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1)'
        }}>
          <button onClick={() => setShowNodeDetail(false)} style={{ 
            position: 'absolute', top: 16, right: 16, 
            background: 'rgba(0, 0, 0, 0.04)', border: 'none', borderRadius: 10, 
            width: 36, height: 36, color: '#666', cursor: 'pointer', fontSize: 18,
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            transition: 'all 0.2s ease'
          }}
          onMouseEnter={e => { e.currentTarget.style.background = 'rgba(0, 0, 0, 0.08)'; e.currentTarget.style.color = '#1A1A1A'; }}
          onMouseLeave={e => { e.currentTarget.style.background = 'rgba(0, 0, 0, 0.04)'; e.currentTarget.style.color = '#666'; }}>×</button>
          
          <div style={{ color: '#1A1A1A' }}>
            <div style={{ marginBottom: 20 }}>
              <div style={{ display: 'flex', gap: 10, marginBottom: 12 }}>
                <StatusPill tone={riskTone(selectedNode.risk_tag)}>{selectedNode.branch_strategy || activeOption?.branch_strategy || '当前分支'}</StatusPill>
                <span style={{ fontSize: 13, color: '#999', display: 'flex', alignItems: 'center', gap: 4 }}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  M{selectedNode.month} / 概率 {formatPercent(selectedNode.probability)}
                </span>
              </div>
              <h3 style={{ fontSize: 20, fontWeight: 800, margin: 0, letterSpacing: '-0.01em', lineHeight: 1.4 }}>{selectedNode.event}</h3>
            </div>
            
            <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
              <div style={{ background: 'rgba(10, 89, 247, 0.04)', borderRadius: 16, padding: 18 }}>
                <div style={{ 
                  fontSize: 12, fontWeight: 700, color: '#0A59F7', marginBottom: 10, 
                  letterSpacing: '0.1em', textTransform: 'uppercase',
                  display: 'flex', alignItems: 'center', gap: 6
                }}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                  状态前
                </div>
                <div style={{ marginTop: 8, display: 'flex', flexDirection: 'column', gap: 6 }}>
                  {stateEntries(selectedNode.state_before).map(([key, value]) => (
                    <span key={key} style={{ fontSize: 14, color: '#666', display: 'flex', alignItems: 'center', gap: 8 }}>
                      <span style={{ color: '#999', minWidth: 60 }}>{key}:</span>
                      <span style={{ color: '#1A1A1A', fontWeight: 500 }}>{String(value)}</span>
                    </span>
                  ))}
                </div>
              </div>
              
              <div style={{ background: 'rgba(107, 72, 255, 0.04)', borderRadius: 16, padding: 18 }}>
                <div style={{ 
                  fontSize: 12, fontWeight: 700, color: '#6B48FF', marginBottom: 10, 
                  letterSpacing: '0.1em', textTransform: 'uppercase',
                  display: 'flex', alignItems: 'center', gap: 6
                }}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                    <polyline points="17 6 23 6 23 12"/>
                  </svg>
                  状态后
                </div>
                <div style={{ marginTop: 8, display: 'flex', flexDirection: 'column', gap: 6 }}>
                  {stateEntries(selectedNode.state_after).map(([key, value]) => (
                    <span key={key} style={{ fontSize: 14, color: '#666', display: 'flex', alignItems: 'center', gap: 8 }}>
                      <span style={{ color: '#999', minWidth: 60 }}>{key}:</span>
                      <span style={{ color: '#1A1A1A', fontWeight: 500 }}>{String(value)}</span>
                    </span>
                  ))}
                </div>
              </div>
              
              <div style={{ background: 'rgba(0, 200, 83, 0.04)', borderRadius: 16, padding: 18 }}>
                <div style={{ 
                  fontSize: 12, fontWeight: 700, color: '#34C759', marginBottom: 10, 
                  letterSpacing: '0.1em', textTransform: 'uppercase',
                  display: 'flex', alignItems: 'center', gap: 6
                }}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"/>
                    <line x1="12" y1="20" x2="12" y2="4"/>
                    <line x1="6" y1="20" x2="6" y2="14"/>
                  </svg>
                  影响向量
                </div>
                <div style={{ marginTop: 10, display: 'flex', flexWrap: 'wrap', gap: 8 }}>
                  {impactEntries(selectedNode.impact_vector).map(([key, value]) => (
                    <span key={key} style={{ 
                      padding: '8px 14px', borderRadius: 12, fontSize: 13, fontWeight: 600, 
                      background: value >= 0 ? 'rgba(52, 199, 89, 0.1)' : 'rgba(255, 59, 48, 0.1)', 
                      color: value >= 0 ? '#34C759' : '#FF3B30', 
                      border: `1px solid ${value >= 0 ? 'rgba(52, 199, 89, 0.2)' : 'rgba(255, 59, 48, 0.2)'}`,
                      transition: 'all 0.2s ease',
                    }}>
                      {key} {value >= 0 ? '+' : ''}{(value * 100).toFixed(0)}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* 错误提示 - HarmonyOS 6 风格 */}
      {error && (
        <div style={{ 
          position: 'absolute', bottom: 24, left: '50%', transform: 'translateX(-50%)', 
          background: 'rgba(255, 255, 255, 0.98)', backdropFilter: 'blur(20px)', 
          border: '1px solid rgba(255, 59, 48, 0.2)', borderRadius: 16, 
          padding: '14px 24px', color: '#FF3B30', fontSize: 14, fontWeight: 600, 
          boxShadow: '0 12px 40px rgba(255, 59, 48, 0.15)', zIndex: 200,
          display: 'flex', alignItems: 'center', gap: 10,
          animation: 'harmonyFadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1)'
        }}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          {error}
        </div>
      )}

      {/* 退出确认对话框 - HarmonyOS 6 风格 */}
      {showExitConfirm && (
        <div style={{
          position: 'fixed', top: 0, left: 0, right: 0, bottom: 0,
          background: 'rgba(0, 0, 0, 0.5)', backdropFilter: 'blur(8px)',
          display: 'flex', alignItems: 'center', justifyContent: 'center',
          zIndex: 1000,
          animation: 'fadeIn 0.2s ease'
        }}>
          <div style={{
            background: '#ffffff', borderRadius: 24, padding: 32,
            width: 480, maxWidth: '90vw',
            boxShadow: '0 24px 80px rgba(0, 0, 0, 0.2)',
            animation: 'scaleIn 0.3s cubic-bezier(0.4, 0, 0.2, 1)'
          }}>
            {/* 图标 */}
            <div style={{
              width: 64, height: 64, borderRadius: '50%',
              background: 'linear-gradient(135deg, rgba(255, 149, 0, 0.1), rgba(255, 59, 48, 0.1))',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              margin: '0 auto 20px'
            }}>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FF9500" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>

            {/* 标题 */}
            <h3 style={{
              fontSize: 22, fontWeight: 800, color: '#1A1A1A',
              textAlign: 'center', margin: '0 0 12px 0',
              letterSpacing: '-0.01em'
            }}>
              推演正在进行中
            </h3>

            {/* 描述 */}
            <p style={{
              fontSize: 15, color: '#666', textAlign: 'center',
              margin: '0 0 28px 0', lineHeight: 1.6
            }}>
              当前推演尚未完成，已生成 <strong style={{ color: '#0A59F7' }}>{Array.from(liveOptions.values()).reduce((sum, opt) => sum + (opt.timeline?.length || 0), 0)}</strong> 个节点。
              <br />
              您希望如何处理这些数据？
            </p>

            {/* 按钮组 */}
            <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
              {/* 保留内容 */}
              <button
                onClick={handleKeepAndExit}
                style={{
                  background: 'linear-gradient(135deg, #0A59F7, #6B48FF)',
                  border: 'none', borderRadius: 14, padding: '14px 24px',
                  color: '#ffffff', fontSize: 15, fontWeight: 700,
                  cursor: 'pointer', transition: 'all 0.3s ease',
                  display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8
                }}
                onMouseEnter={e => { e.currentTarget.style.transform = 'translateY(-2px)'; e.currentTarget.style.boxShadow = '0 8px 24px rgba(10, 89, 247, 0.3)'; }}
                onMouseLeave={e => { e.currentTarget.style.transform = 'translateY(0)'; e.currentTarget.style.boxShadow = 'none'; }}
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                  <polyline points="17 21 17 13 7 13 7 21"/>
                  <polyline points="7 3 7 8 15 8"/>
                </svg>
                保留内容并退出
              </button>

              {/* 清空内容 */}
              <button
                onClick={handleClearAndExit}
                style={{
                  background: 'rgba(255, 59, 48, 0.1)',
                  border: '1px solid rgba(255, 59, 48, 0.2)',
                  borderRadius: 14, padding: '14px 24px',
                  color: '#FF3B30', fontSize: 15, fontWeight: 600,
                  cursor: 'pointer', transition: 'all 0.3s ease',
                  display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 8
                }}
                onMouseEnter={e => { e.currentTarget.style.background = 'rgba(255, 59, 48, 0.15)'; }}
                onMouseLeave={e => { e.currentTarget.style.background = 'rgba(255, 59, 48, 0.1)'; }}
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                  <line x1="10" y1="11" x2="10" y2="17"/>
                  <line x1="14" y1="11" x2="14" y2="17"/>
                </svg>
                清空内容并退出
              </button>

              {/* 取消 */}
              <button
                onClick={handleCancelExit}
                style={{
                  background: 'transparent',
                  border: '1px solid rgba(0, 0, 0, 0.1)',
                  borderRadius: 14, padding: '14px 24px',
                  color: '#666', fontSize: 15, fontWeight: 600,
                  cursor: 'pointer', transition: 'all 0.3s ease'
                }}
                onMouseEnter={e => { e.currentTarget.style.background = 'rgba(0, 0, 0, 0.04)'; e.currentTarget.style.color = '#1A1A1A'; }}
                onMouseLeave={e => { e.currentTarget.style.background = 'transparent'; e.currentTarget.style.color = '#666'; }}
              >
                继续推演
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
