# LifeSwarm 2核2GB优化配置
# 适用于低配置云服务器

# ==================== 环境配置 ====================
LIFESWARM_ENV=production

# ==================== 知识图谱配置 ====================
USE_NEO4J=true
USE_INFORMATION_KG=true

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lifeswarm123
NEO4J_DATABASE=neo4j

# ==================== 数据库配置 ====================
DB_TYPE=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=lifeswarm
MYSQL_PASSWORD=lifeswarm123
MYSQL_DATABASE=lifeswarm

# ==================== 缓存配置 ====================
CACHE_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=lifeswarm:

# ==================== 大模型配置 ====================
LLM_PROVIDER=qwen
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI (备用)
OPENAI_API_KEY=your_openai_api_key_here

# ==================== 数据库连接池优化 ====================
# 减少连接池大小以节省内存
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=20
DB_POOL_RECYCLE=1800

# ==================== 缓存优化 ====================
CACHE_DEFAULT_TTL=1800
CACHE_MAX_SIZE=500

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=5001
DEBUG=false

# ==================== 性能优化 ====================
# 限制并发请求数
MAX_WORKERS=1
MAX_CONCURRENT_REQUESTS=5

# 禁用不必要的功能
ENABLE_METRICS=false
ENABLE_TRACING=false
