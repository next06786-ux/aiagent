<?xml version="1.0" encoding="utf-8"?>
<!--
    网络安全配置
    云服务器: http://82.157.195.238:8000 (后端)
    云服务器: http://82.157.195.328 (web前端)
-->
<network-security-config>
    <!-- 允许云服务器明文 HTTP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">82.157.195.238</domain>
        <domain includeSubdomains="true">82.157.195.328</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.100.130.117</domain>
        <domain includeSubdomains="false">10.22.13.153</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
