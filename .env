# ==================== LifeSwarm 统一环境配置 ====================
# 生产环境 - Docker部署

# ==================== 部署模式 ====================
LIFESWARM_ENV=production

# ==================== 服务端口 ====================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ==================== 数据库配置 - MySQL ====================
DB_TYPE=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=lifeswarm
MYSQL_PASSWORD=lifeswarm_secure_password_2024
MYSQL_DATABASE=lifeswarm
MYSQL_ROOT_PASSWORD=root_secure_password_2024

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== 知识图谱配置 - Neo4j ====================
USE_NEO4J=true
USE_INFORMATION_KG=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secure_password_2024
NEO4J_DATABASE=neo4j

# ==================== 缓存配置 - Redis ====================
CACHE_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_2024
CACHE_DEFAULT_TTL=3600
CACHE_MAX_SIZE=1000

# ==================== 大模型配置 ====================
# 可选值: qwen, openai, remote_model, local_quantized
# qwen: 通义千问云端API（推荐，速度快）
# remote_model: 远程基座模型（自建服务器，成本低）
# local_quantized: 本地量化模型（离线使用）
# openai: OpenAI API（备用）
LLM_PROVIDER=qwen

# 远程模型服务器地址（当 LLM_PROVIDER=remote_model 时使用）
# 注意：需要在远程服务器控制台添加 8001 端口映射
# 映射后将类似: https://u821458-89e7-xxxxx.westc.seetacloud.com:8443
REMOTE_MODEL_URL=https://u821458-b49a-bdca5515.westc.seetacloud.com:8443

# 通义千问配置（阿里云）- 请填入你的真实API密钥
DASHSCOPE_API_KEY=sk-e2402dc10eea46a696f548ab7f909696
QWEN_API_KEY=sk-e2402dc10eea46a696f548ab7f909696

# 通义千问联网搜索配置（阿里云 OpenSearch AI搜索）
QWEN_SEARCH_API_KEY=OS-j31gv5qdy6lv27j4
QWEN_SEARCH_WORKSPACE=default
QWEN_SEARCH_SERVICE_ID=ops-web-search-001
QWEN_SEARCH_HOST=http://default-9f2v.platform-cn-shanghai.opensearch.aliyuncs.com

# DeepSeek配置（备用）- 请填入你的真实API密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI 配置（备用）
OPENAI_API_KEY=your_openai_api_key_here

# 聚合数据联网搜索API配置
JUHE_SEARCH_API_KEY=99ce6f870f818d567cc7045f7b492972

# 决策推演模式（api=云端推理, lora=本地模型）
DECISION_INFERENCE_MODE=api

# 本地模型配置（仅在需要时启用）
ENABLE_LOCAL_MODEL=true
LOCAL_MODEL_PATH=/root/autodl-tmp/quarot_qwen3-8b_w4a16kv16_s50.pt
LOCAL_BASE_MODEL_PATH=/root/autodl-tmp/models/base/Qwen3.5-9B
LORA_MODELS_DIR=./models/lora

# ==================== API 配置 ====================
API_BASE_URL=http://backend:8000
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
CORS_ORIGINS=*

# ==================== 性能优化配置 ====================
# LLM并发配置
LLM_MAX_CONNECTIONS=500
LLM_MAX_KEEPALIVE=100
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# Agent推演配置
AGENT_PARALLEL_LIMIT=0
OPTION_PARALLEL_LIMIT=0

# 教育Agent LLM模式
EDUCATION_AGENT_LLM_MODE=FULL

# 性能监控
ENABLE_PERFORMANCE_LOGGING=true
LOG_LLM_TIMING=true

# ==================== 其他配置 ====================
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads
AUTONOMOUS_ENABLED=true
AUTONOMOUS_CHECK_INTERVAL=3600

# Embedding 维度（text-embedding-v3 = 1024）
EMBEDDING_DIM=1024

# ChromaDB 向量数据库（嵌入式模式）
CHROMA_PATH=./data/chroma
