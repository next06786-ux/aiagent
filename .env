# LifeSwarm 环境配置
LIFESWARM_ENV=production

# 知识图谱配置 - Neo4j（设置为 true 启用）
USE_NEO4J=true

# 信息中心知识图谱 - 新架构（推荐）
USE_INFORMATION_KG=true

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lifeswarm123
NEO4J_DATABASE=neo4j

# 数据库配置 - MySQL
DB_TYPE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=lifeswarm

# 缓存配置 - 使用 Redis
CACHE_TYPE=redis

# 大模型配置
LLM_PROVIDER=qwen

# 本地基座模型配置（决策模拟主链路）
LOCAL_BASE_MODEL_PATH=/root/autodl-tmp/models/base/Qwen3.5-9B
LORA_MODELS_DIR=./models/lora
API_BASE_URL=http://127.0.0.1:6006

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here

# 通义千问配置（阿里云）
DASHSCOPE_API_KEY=sk-e2402dc10eea46a696f548ab7f909696

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 缓存配置
CACHE_DEFAULT_TTL=3600
CACHE_MAX_SIZE=1000
