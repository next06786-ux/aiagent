# 生产环境配置 - 服务器 152.136.13.236
# 复制此文件为 .env 并填写实际值

# ==================== 数据库配置 ====================
# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=lifeswarm
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=lifeswarm

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ==================== LLM配置 ====================
# LLM提供商: qwen 或 deepseek
LLM_PROVIDER=qwen

# 通义千问API密钥
QWEN_API_KEY=your_qwen_api_key_here

# DeepSeek API密钥（可选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==================== 系统配置 ====================
# 禁用本地模型（节省内存）
ENABLE_LOCAL_MODEL=false

# HuggingFace离线模式
HF_HUB_OFFLINE=1

# ==================== 服务器配置 ====================
# 服务器IP
SERVER_IP=152.136.13.236

# 前端API地址
VITE_API_BASE_URL=http://152.136.13.236:8000
VITE_WS_BASE_URL=ws://152.136.13.236:8000
